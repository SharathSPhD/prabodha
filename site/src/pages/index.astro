---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
import Act1Problem from '@/components/scenes/Act1Problem.astro';
import Act2Doctrine from '@/components/scenes/Act2Doctrine.astro';
import Act3Machine from '@/components/scenes/Act3Machine.astro';
import Act4Evidence from '@/components/scenes/Act4Evidence.astro';
import Act5Negatives from '@/components/scenes/Act5Negatives.astro';
import Act6Moat from '@/components/scenes/Act6Moat.astro';
import Act7Value from '@/components/scenes/Act7Value.astro';
import Coda from '@/components/Coda.astro';
import DepthToggle from '@/components/DepthToggle.astro';
---

<Base
  title="Prabodha — An Ancient Manual for Steering an AI's Mind"
  description="An interactive essay: how a 10th-century theory of recognition became a tested control method for language models — and a jailbreak defense that reads intent, not wording. Every number traces to a public evidence record."
>
  <Nav />
  <Hero />

  <div style="background-color: var(--bg);">
    <!-- Act I: the actuator without a doctrine -->
    <Act1Problem />

    <!-- Act II: Pratyabhijñā as engineering specification -->
    <Act2Doctrine />

    <!-- Act III: the auto-research machine -->
    <Act3Machine />

    <!-- Act IV: the evidence (findings + live trace player) -->
    <Act4Evidence />

    <!-- Act V: registered negatives -->
    <Act5Negatives />

    <!-- Act VI: the recognition-gated defense (+ live captures) -->
    <Act6Moat />

    <!-- Act VII: concept → value -->
    <Act7Value />

    <!-- Coda: provenance, author, references -->
    <Coda />
  </div>

  <!-- Explorer / Researcher depth toggle -->
  <DepthToggle />
</Base>
