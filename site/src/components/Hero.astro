---
// Hero — dark editorial opening, ACD style: huge Newsreader display,
// italic violet accent, constellation background, left-aligned.
---

<header id="top" class="hero on-night">
  <canvas id="hero-stars" aria-hidden="true"></canvas>

  <div class="hero-inner">
    <p class="scene-label" style="margin-bottom: 1.6rem;">An interactive essay · Prabodha · प्रबोध, “awakening”</p>

    <h1>
      An Ancient Manual<br />
      for <em>Steering an AI's Mind</em>
    </h1>

    <p class="hero-lede">
      Researchers recently found the place where a language model
      <em class="accent">talks to itself</em> — and built a pen that can write there.
      Nobody knew the rules. This is the story of finding them in a
      thousand-year-old philosophy of recognition, testing every one of them
      to destruction, and ending up with a guardrail that jailbreaks
      can't talk their way past.
    </p>

    <p class="hero-byline">
      by <strong>Dr. Sharath Sathish</strong> · a guided tour for the curious and the technical alike
    </p>

    <figure class="hero-cover">
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/cover.png`} target="_blank" rel="noopener" style="border-bottom:none; display:block;">
        <img
          src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/cover.webp`}
          alt="Graphical abstract: Pratyabhijñā philosophy translated into five falsifiable engineering clauses, the transformer workspace, the recognition-gated control loop, experimental validation, and real-world outcomes"
          width="1536" height="1024"
          loading="eager"
        />
      </a>
      <figcaption>The whole story in one picture — click to open full-size. Every panel is unpacked below.</figcaption>
    </figure>

    <a href="#act-1" class="hero-scroll">Scroll to begin <span class="arr">↓</span></a>
  </div>
</header>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(900px 500px at 78% 12%, rgba(180, 155, 240, 0.08), transparent 60%),
      radial-gradient(700px 420px at 8% 92%, rgba(79, 216, 206, 0.06), transparent 60%),
      linear-gradient(160deg, #080b11 0%, #0a0d14 60%, #0b0e16 100%);
  }

  #hero-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: var(--maxw-wide);
    width: 100%;
    margin: 0 auto;
    padding: 7rem 1.6rem 5rem;
  }

  .hero h1 {
    color: var(--night-ink);
    font-size: clamp(2.9rem, 7.6vw, 5.7rem);
    font-weight: 500;
    letter-spacing: -0.022em;
    line-height: 1.03;
    margin-bottom: 2.2rem;
    max-width: 1050px;
  }

  .hero h1 em {
    font-style: italic;
    color: #cdbdf6;
  }

  .hero-lede {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.3vw, 1.55rem);
    line-height: 1.55;
    color: var(--night-ink-soft);
    max-width: 720px;
    margin-bottom: 2.2rem;
  }

  .hero-lede .accent {
    color: var(--violet);
    font-style: italic;
  }

  .hero-byline {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--night-ink-faint);
    margin-bottom: 2.4rem;
  }

  .hero-byline strong { color: var(--night-ink); font-weight: 600; }

  .hero-cover {
    margin: 0 0 3.2rem;
    max-width: 980px;
  }

  .hero-cover img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(237, 232, 220, 0.14);
    transition: transform 0.3s ease;
  }

  .hero-cover a:hover img { transform: translateY(-3px); }

  .hero-cover figcaption {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--night-ink-faint);
    margin-top: 0.7rem;
  }

  .hero-scroll {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--night-ink-faint);
    border-bottom: none;
    transition: color 0.25s ease;
  }

  .hero-scroll:hover { color: var(--teal-bright); }

  .hero-scroll .arr {
    display: inline-block;
    animation: bob 2.2s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }
</style>

<script is:inline>
  // Subtle constellation: drifting points, faint links — pure canvas, no deps.
  (function () {
    const c = document.getElementById('hero-stars');
    if (!c) return;
    const ctx = c.getContext('2d');
    let w, h, pts;
    const N = 70;

    function reset() {
      w = c.width = c.offsetWidth * devicePixelRatio;
      h = c.height = c.offsetHeight * devicePixelRatio;
      pts = Array.from({ length: N }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.12 * devicePixelRatio,
        vy: (Math.random() - 0.5) * 0.12 * devicePixelRatio,
        r: (Math.random() * 1.4 + 0.5) * devicePixelRatio,
        tw: Math.random() * Math.PI * 2,
      }));
    }

    function tick(t) {
      ctx.clearRect(0, 0, w, h);
      const linkDist = 130 * devicePixelRatio;
      for (let i = 0; i < N; i++) {
        const p = pts[i];
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;
        for (let j = i + 1; j < N; j++) {
          const q = pts[j];
          const dx = p.x - q.x, dy = p.y - q.y;
          const d = Math.hypot(dx, dy);
          if (d < linkDist) {
            ctx.strokeStyle = `rgba(140, 147, 163, ${(0.09 * (1 - d / linkDist)).toFixed(3)})`;
            ctx.lineWidth = devicePixelRatio * 0.5;
            ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(q.x, q.y); ctx.stroke();
          }
        }
        const glow = 0.35 + 0.3 * Math.sin(t / 1400 + p.tw);
        ctx.fillStyle = `rgba(205, 210, 222, ${glow.toFixed(3)})`;
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fill();
      }
      requestAnimationFrame(tick);
    }

    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
      reset();
      addEventListener('resize', reset);
      requestAnimationFrame(tick);
    }
  })();
</script>
