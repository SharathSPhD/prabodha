---
// Hero: animated J-space band visualization with tokens
// The thesis in motion.
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden bg-gradient-to-b from-primary via-band to-gray-800">
  <!-- Background visualization: J-space band with animated tokens -->
  <div id="hero-band" class="absolute inset-0 opacity-60"></div>

  <!-- Content -->
  <div class="relative z-10 prose-section text-center text-white">
    <h1 class="text-5xl md:text-7xl font-serif font-semibold mb-6 leading-tight">
      recognition<span class="text-bright">—</span>gated
    </h1>
    <h1 class="text-5xl md:text-7xl font-serif font-semibold mb-12 leading-tight">
      workspace steering
    </h1>

    <p class="text-xl md:text-2xl font-light mb-8 max-w-3xl mx-auto">
      Steer a frozen language model through its verbalizable workspace. Writes timed by <em>sphuraṭṭā</em> events (uncommitted moments). Verified by <em>āgama</em> re-cognition. Bounded by <em>svātantrya</em> (autonomy).
    </p>

    <div class="flex gap-4 justify-center mt-12 flex-wrap">
      <a href="#parallel" class="cta-button">See the parallel</a>
      <a href="#instrument" class="secondary-button">Read the research</a>
    </div>

    <p class="text-sm md:text-base text-neutral mt-16">
      Prabodha v1.0.0 · Verified across 20+ gates · Core claim: 0.30–0.35 lift within ±0.5 nat budget
    </p>
  </div>
</section>

<script>
  // Simple band visualization with animated tokens
  const canvas = document.getElementById('hero-band');
  if (canvas && typeof window !== 'undefined') {
    // Create SVG visualization
    const svg = `
      <svg viewBox="0 0 1200 400" class="w-full h-full">
        <defs>
          <linearGradient id="bandGrad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" style="stop-color:#3d3d5c;stop-opacity:0.8" />
            <stop offset="50%" style="stop-color:#4a4a6a;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#2a2a3e;stop-opacity:0.8" />
          </linearGradient>
        </defs>

        <!-- Band region -->
        <rect y="150" width="1200" height="100" fill="url(#bandGrad)" />

        <!-- Workspace boundary -->
        <line x1="0" y1="150" x2="1200" y2="150" stroke="#ffd166" stroke-width="2" opacity="0.3" />
        <line x1="0" y1="250" x2="1200" y2="250" stroke="#ffd166" stroke-width="2" opacity="0.3" />

        <!-- Animated tokens (represented as dots) -->
        <circle cx="100" cy="200" r="4" fill="#ffd166" opacity="0.8" class="token" />
        <circle cx="300" cy="190" r="4" fill="#ffd166" opacity="0.6" class="token" />
        <circle cx="500" cy="210" r="4" fill="#e94b3c" opacity="0.9" class="token" />
        <circle cx="700" cy="195" r="4" fill="#ffd166" opacity="0.5" class="token" />
        <circle cx="900" cy="205" r="4" fill="#ffd166" opacity="0.7" class="token" />
        <circle cx="1100" cy="185" r="4" fill="#ffd166" opacity="0.4" class="token" />

        <!-- Label -->
        <text x="600" y="380" text-anchor="middle" fill="#d4d4d4" font-family="mono" font-size="12">
          J-space workspace band | Tokens flow through verbalizable representations
        </text>
      </svg>
    `;
    canvas.innerHTML = svg;
  }
</script>

<style>
  #hero-band {
    animation: fadeInUp 0.8s ease-out;
  }

  .token {
    animation: drift 4s infinite ease-in-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes drift {
    0%, 100% {
      transform: translateY(0) scaleOpacity(1);
    }
    50% {
      transform: translateY(-10px) scaleOpacity(0.7);
    }
  }
</style>
