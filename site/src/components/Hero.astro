---
// Hero: animated J-space band visualization with tokens
// The thesis in motion — neuro-lab bioluminescent aesthetic.
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden" style="background: linear-gradient(135deg, #0a0e14 0%, #111824 50%, #0d1420 100%);">
  <!-- Background visualization: J-space band with animated tokens -->
  <div id="hero-band" class="absolute inset-0 opacity-70"></div>

  <!-- Content -->
  <div class="relative z-10 prose-section text-center">
    <div class="mb-8 inline-block">
      <span class="scene-label">Introduction</span>
    </div>

    <h1 class="text-5xl md:text-7xl font-serif font-semibold mb-4 leading-tight text-ink">
      recognition<span class="text-cyan">—</span>gated
    </h1>
    <h1 class="text-5xl md:text-7xl font-serif font-semibold mb-12 leading-tight text-ink">
      workspace steering
    </h1>

    <p class="text-lg md:text-xl font-light mb-8 max-w-3xl mx-auto text-ink-soft">
      Steer a frozen language model through its verbalizable workspace. Writes timed by <em class="text-cyan">sphuraṭṭā</em> events (uncommitted moments). Verified by <em class="text-violet">āgama</em> re-cognition. Bounded by <em class="text-amber">svātantrya</em> (autonomy).
    </p>

    <div class="flex gap-4 justify-center mt-12 flex-wrap">
      <a href="#parallel" class="cta-button">See the parallel →</a>
      <a href="#instrument" class="secondary-button">Read the research</a>
    </div>

    <div class="mt-16 pt-8 border-t border-hairline">
      <p class="text-sm md:text-base text-ink-faint">
        Prabodha v1.0.0 · Verified across 20+ gates · Core claim: 0.30–0.35 lift within ±0.5 nat budget
      </p>
    </div>
  </div>
</section>

<script>
  // Animated J-space band visualization
  const canvas = document.getElementById('hero-band');
  if (canvas && typeof window !== 'undefined') {
    const svg = `
      <svg viewBox="0 0 1200 400" class="w-full h-full">
        <defs>
          <linearGradient id="bandGrad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" style="stop-color:#1d2d4d;stop-opacity:0.9" />
            <stop offset="50%" style="stop-color:#2a3f5f;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#1a2a40;stop-opacity:0.9" />
          </linearGradient>
          <filter id="glow">
            <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
            <feMerge>
              <feMergeNode in="coloredBlur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>

        <!-- Band region with glow -->
        <rect y="140" width="1200" height="120" fill="url(#bandGrad)" opacity="0.8" />

        <!-- Workspace boundary lines -->
        <line x1="0" y1="140" x2="1200" y2="140" stroke="#22d3ee" stroke-width="1" opacity="0.4" />
        <line x1="0" y1="260" x2="1200" y2="260" stroke="#a855f7" stroke-width="1" opacity="0.3" />

        <!-- Animated tokens with glow -->
        <circle cx="100" cy="200" r="5" fill="#22d3ee" opacity="0.9" class="token" filter="url(#glow)" />
        <circle cx="300" cy="185" r="4" fill="#22d3ee" opacity="0.6" class="token" />
        <circle cx="500" cy="215" r="5" fill="#f59e0b" opacity="0.8" class="token" filter="url(#glow)" />
        <circle cx="700" cy="200" r="4" fill="#22d3ee" opacity="0.5" class="token" />
        <circle cx="900" cy="210" r="5" fill="#a855f7" opacity="0.7" class="token" filter="url(#glow)" />
        <circle cx="1100" cy="190" r="4" fill="#22d3ee" opacity="0.4" class="token" />

        <!-- Label -->
        <text x="600" y="380" text-anchor="middle" fill="#aebacb" font-family="monospace" font-size="12">
          J-space workspace band | sphuraṭṭā writes flow through verbalizable representations
        </text>
      </svg>
    `;
    canvas.innerHTML = svg;
  }
</script>

<style>
  #hero-band {
    animation: fadeInUp 1s ease-out;
  }

  .token {
    animation: drift 5s infinite ease-in-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes drift {
    0%, 100% {
      transform: translateY(0);
      opacity: 0.6;
    }
    50% {
      transform: translateY(-12px);
      opacity: 0.95;
    }
  }
</style>
