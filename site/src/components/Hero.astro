---
// Hero: the essay's hook, over the animated J-space band visualization.
---

<section id="top" class="min-h-screen flex items-center justify-center relative overflow-hidden" style="background: linear-gradient(135deg, #0a0e14 0%, #111824 50%, #0d1420 100%);">
  <!-- Background visualization: J-space band with animated tokens -->
  <div id="hero-band" class="absolute inset-0 opacity-70"></div>

  <!-- Content -->
  <div class="relative z-10 prose-section text-center pt-24 pb-16">
    <p class="scene-label mb-6">An interactive essay · prabodha — प्रबोध, “awakening”</p>

    <h1 class="text-4xl md:text-6xl font-serif font-semibold mb-6 leading-tight" style="color: var(--ink);">
      A Thousand-Year-Old Theory of Mind,<br class="hidden md:block" />
      Running Inside a Language Model
    </h1>

    <p class="text-lg md:text-xl font-light mb-4 max-w-3xl mx-auto" style="color: var(--ink-soft);">
      Interpretability researchers recently found the place where a language model
      <em>talks to itself</em> — and built a pen that can write there. Nobody knew the grammar.
      This is the story of borrowing one from a 10th-century Kashmiri philosophy of recognition,
      turning it into falsifiable engineering, and ending up with a jailbreak defense
      that lives where attackers can't reach.
    </p>

    <p class="text-sm mb-10" style="color: var(--ink-faint);">
      by <strong style="color: var(--ink-soft);">Sharath Sathish</strong> · a guided tour for the curious and the technical alike
    </p>

    <div class="flex gap-4 justify-center flex-wrap">
      <a href="#act-1" class="cta-button">Scroll to begin ↓</a>
      <a href="#act-6" class="secondary-button">Skip to the jailbreak moat</a>
    </div>

    <div class="mt-16 pt-8" style="border-top: 1px solid var(--hairline);">
      <p class="text-sm" style="color: var(--ink-faint);">
        v1.0.0 · 130 gate records · every number on this page traces to a committed gate file ·
        core claim replicated at 6 seeds (p = 0.016)
      </p>
    </div>
  </div>
</section>

<script>
  // Animated J-space band visualization
  const canvas = document.getElementById('hero-band');
  if (canvas && typeof window !== 'undefined') {
    const svg = `
      <svg viewBox="0 0 1200 400" class="w-full h-full" preserveAspectRatio="xMidYMid slice">
        <defs>
          <linearGradient id="bandGrad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" style="stop-color:#1d2d4d;stop-opacity:0.9" />
            <stop offset="50%" style="stop-color:#2a3f5f;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#1a2a40;stop-opacity:0.9" />
          </linearGradient>
          <filter id="glow">
            <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
            <feMerge>
              <feMergeNode in="coloredBlur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>

        <!-- Band region with glow -->
        <rect y="140" width="1200" height="120" fill="url(#bandGrad)" opacity="0.8" />

        <!-- Workspace boundary lines -->
        <line x1="0" y1="140" x2="1200" y2="140" stroke="#22d3ee" stroke-width="1" opacity="0.4" />
        <line x1="0" y1="260" x2="1200" y2="260" stroke="#a855f7" stroke-width="1" opacity="0.3" />

        <!-- Animated tokens with glow -->
        <circle cx="100" cy="200" r="5" fill="#22d3ee" opacity="0.9" class="token" filter="url(#glow)" />
        <circle cx="300" cy="185" r="4" fill="#22d3ee" opacity="0.6" class="token" />
        <circle cx="500" cy="215" r="5" fill="#f59e0b" opacity="0.8" class="token" filter="url(#glow)" />
        <circle cx="700" cy="200" r="4" fill="#22d3ee" opacity="0.5" class="token" />
        <circle cx="900" cy="210" r="5" fill="#a855f7" opacity="0.7" class="token" filter="url(#glow)" />
        <circle cx="1100" cy="190" r="4" fill="#22d3ee" opacity="0.4" class="token" />

        <!-- Label -->
        <text x="600" y="380" text-anchor="middle" fill="#aebacb" font-family="monospace" font-size="12">
          the J-space workspace band — the late layers where representations become verbalizable
        </text>
      </svg>
    `;
    canvas.innerHTML = svg;
  }
</script>

<style>
  #hero-band {
    animation: fadeInUp 1s ease-out;
  }

  .token {
    animation: drift 5s infinite ease-in-out;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes drift {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50% { transform: translateY(-12px); opacity: 0.95; }
  }
</style>
