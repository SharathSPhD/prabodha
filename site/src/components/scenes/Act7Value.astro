---
import ActBreak from '../ActBreak.astro';

const surfaces = [
  {
    title: 'The live app',
    what: 'Watch real steering episodes replay, harden any model at the prompt level with your own API key, and publish your hardening pack to your own HuggingFace account. No install.',
    link: 'https://prabodha-live.vercel.app',
    linkText: 'prabodha-live.vercel.app',
    tag: 'start here',
  },
  {
    title: 'Python library + CLI',
    what: 'Fit a reading lens on any open model, run rule-following steering episodes with verification and budget enforcement, or regenerate every figure in this essay from the evidence files.',
    code: 'pip install prabodha',
    link: 'https://pypi.org/project/prabodha/',
    linkText: 'PyPI',
    tag: 'pip',
  },
  {
    title: 'Claude Code plugin',
    what: 'Three agent skills — map a model\'s journal band, run a verified steering episode, and propose the next experiment — each answer citing its evidence file.',
    code: '/plugin install integrations/claude-code-plugin',
    link: 'https://github.com/SharathSPhD/prabodha/tree/main/integrations/claude-code-plugin',
    linkText: 'plugin source',
    tag: 'agents',
  },
  {
    title: 'MCP server',
    what: 'Eight tools for any MCP client: read the journal, steer, verify, list evidence — plus the graded defense menu: characterize a model, get a recommendation, apply a hardening tier.',
    code: 'pip install -e integrations/prabodha_mcp_server && prabodha-mcp',
    link: 'https://github.com/SharathSPhD/prabodha/tree/main/integrations/prabodha_mcp_server',
    linkText: 'server source',
    tag: 'mcp',
  },
  {
    title: 'Steering gateway',
    what: 'A self-hosted streaming service that exposes real model internals to the app — concept, contrastive, and explicit-vector steering behind bearer auth. Powers the app\'s Live mode.',
    link: 'https://github.com/SharathSPhD/prabodha/tree/main/services/steer-gateway',
    linkText: 'gateway source',
    tag: 'self-host',
  },
  {
    title: 'Pre-fitted lenses',
    what: 'Ready-made reading lenses, band maps, fit statistics and chance baselines for Qwen3-4B, Qwen3.6-27B and Nemotron-Mini-4B — skip the fitting step entirely.',
    code: 'huggingface-cli download qbz506/prabodha-lenses',
    link: 'https://huggingface.co/qbz506/prabodha-lenses',
    linkText: 'HuggingFace',
    tag: 'weights',
  },
];
---

<ActBreak
  roman="Act VII"
  title="From Paper to"
  accent="Product"
  tease="One rulebook, six ways in — pick yours by what you can touch and what you can tolerate."
  id="value"
/>

<section class="section-divider" id="get-started">
  <div class="prose-section-wide">
    <div class="prose-section" style="padding-left:0; padding-right:0;">
      <div class="num-label"><span class="num">20</span> Use it</div>
      <h2>Bring your model. Test it. Harden it.</h2>
      <p>
        The product built on this research is deliberately simple to describe:
        <strong>bring any model</strong> — one you host yourself, or any commercial model via your
        own API key. <strong>Characterize it</strong>: measure how susceptible it is to jailbreaks
        and whether the intent signature separates cleanly (the pre-flight test from Act VI).
        Then <strong>harden it from a graded menu</strong> — gentle prompt-level measures for any
        model, up to the full recognition-gated defense for open weights. A menu with measured
        trade-offs, not a promise of magic.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 my-10">
      {surfaces.map((s) => (
        <div class="card card-teal">
          <div class="flex items-baseline justify-between gap-2 mb-1">
            <h4 style="margin:0;">{s.title}</h4>
            <span class="gate-chip">{s.tag}</span>
          </div>
          <p style="font-size:0.98rem; margin-bottom:0.6rem;">{s.what}</p>
          {s.code && <pre style="padding:0.55rem 0.9rem; margin:0 0 0.6rem;"><code>{s.code}</code></pre>}
          <a href={s.link} style="font-family: var(--font-sans); font-size:0.9rem; font-weight:600;">{s.linkText} →</a>
        </div>
      ))}
    </div>

    <div class="prose-section" style="padding-left:0; padding-right:0;">
      <details class="expand">
        <summary>Sixty-second quickstart (researchers)</summary>
        <div class="expand-body">
          <pre><code>pip install prabodha[lens]

# fit a band-targeted lens on your model
prabodha lens-fit --model Qwen/Qwen3-4B-Instruct-2507

# run an entropy-gated steering episode with readback
prabodha steer --concept fire --emit-trace --readback

# reproduce every paper figure from the gate ledger
prabodha figures</code></pre>
          <p style="font-size:0.9rem;">
            Worked examples: <a href="https://github.com/SharathSPhD/prabodha/blob/main/examples/quickstart_qwen3.md">quickstart_qwen3.md</a> ·
            <a href="https://github.com/SharathSPhD/prabodha/blob/main/examples/quickstart_nemotron.md">quickstart_nemotron.md</a>
          </p>
        </div>
      </details>
    </div>
  </div>
</section>
