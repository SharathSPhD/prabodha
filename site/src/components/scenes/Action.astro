---
// A REAL animated trace player — loads public/data/replays/trained_bridge_qwen3.json
// and replays it token-by-token with the actual per-token entropy and the real
// gated-write flashes. Stats are computed from the trace itself.
---

<section id="action" class="section-divider" style="padding-top:0;">
  <div class="prose-section">
    <div class="num-label"><span class="num">10</span> Live replay</div>
    <h2>Watch one steered thought happen</h2>

    <p>
      Below is a <strong>real recorded episode</strong> — not an animation designed to look nice.
      The concept is <em>fire</em>; the model is writing a continuation. Press play: tokens stream
      out with their actual measured "undecidedness" (entropy), and an
      <span style="color: var(--amber); font-weight:600;">amber flash</span> marks each moment the
      gate opened and a write landed — the pauses the rulebook says to wait for.
    </p>

    <div class="my-10 panel" style="padding: 1.6rem;">
      <div id="trace-player" class="w-full flex flex-col">
        <div id="token-stream" class="min-h-[10rem] rounded p-4 mb-4 overflow-y-auto max-h-64" style="background-color: var(--paper-inset); border: 1px solid var(--hairline); font-family: var(--font-serif); font-size: 1.02rem; line-height: 1.7; color: var(--ink-soft);">
          <span style="color: var(--ink-mute);">Press play to stream the trace…</span>
        </div>
        <div class="flex items-center gap-4 mb-4 flex-wrap" style="font-family: var(--font-sans); font-size: 0.78rem; color: var(--ink-faint);">
          <span>entropy: <span id="entropy-readout" style="color: var(--amber); font-weight:600;">—</span></span>
          <span>token <span id="token-idx" style="color: var(--teal-deep); font-weight:600;">0</span>/<span id="token-total">0</span></span>
          <span id="gate-indicator" class="px-2 py-0.5 rounded-full" style="color: var(--ink-mute); border: 1px solid var(--hairline);">gate idle</span>
        </div>
        <div class="flex gap-2 items-center">
          <button id="play-button" class="cta-button" style="padding: 0.5rem 1.3rem; font-size: 0.85rem; cursor: pointer;">▶ Play</button>
          <button id="reset-button" class="pill-link" style="cursor: pointer; background: transparent;">↺ Reset</button>
          <div class="flex-1 rounded-full h-2 cursor-pointer" id="progress-bar" style="background-color: var(--paper-inset); border: 1px solid var(--hairline-soft);">
            <div id="progress-fill" class="rounded-full" style="background-color: var(--teal-deep); height: 100%; width: 0%;"></div>
          </div>
          <span id="time-display" style="font-family: var(--font-sans); font-size: 0.78rem; width: 3.5rem; text-align: right; color: var(--ink-mute);">0/0</span>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-3 gap-3 text-center">
        <div class="panel p-4">
          <div style="font-family: var(--font-serif); font-size: 1.5rem; font-weight: 500; color: var(--amber);">0.44</div>
          <div style="font-family: var(--font-sans); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 0.4rem; color: var(--ink-mute);">measured lift, this configuration</div>
        </div>
        <div class="panel p-4">
          <div style="font-family: var(--font-serif); font-size: 1.5rem; font-weight: 500; color: var(--green);">✓</div>
          <div style="font-family: var(--font-sans); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 0.4rem; color: var(--ink-mute);">within freedom budget</div>
        </div>
        <div class="panel p-4">
          <div id="gated-count" style="font-family: var(--font-serif); font-size: 1.5rem; font-weight: 500; color: var(--teal-deep);">—</div>
          <div style="font-family: var(--font-sans); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 0.4rem; color: var(--ink-mute);">gated writes in this trace</div>
        </div>
      </div>
    </div>

    <div class="flex gap-3 flex-wrap">
      <a href="https://prabodha-live.vercel.app/theatre" target="_blank" rel="noopener noreferrer" class="cta-button">
        Steer one yourself →
      </a>
      <a href="#timing" class="secondary-button">Keep reading ↓</a>
    </div>

    <p class="mt-6" style="font-family: var(--font-sans); font-size: 0.8rem; color: var(--ink-mute);">
      Trace source: gate_L20_confirm, seed 42 · Model: Qwen3-4B, temperature 0.8 · Concept: fire (pre-registered target)
    </p>
  </div>
</section>

<script>
  const base = import.meta.env.BASE_URL || "/";
  const url = (base.endsWith("/") ? base : base + "/") + "data/replays/trained_bridge_qwen3.json";

  const stream = document.getElementById("token-stream");
  const entropyReadout = document.getElementById("entropy-readout");
  const tokenIdx = document.getElementById("token-idx");
  const tokenTotal = document.getElementById("token-total");
  const gateIndicator = document.getElementById("gate-indicator");
  const playButton = document.getElementById("play-button");
  const resetButton = document.getElementById("reset-button");
  const progressFill = document.getElementById("progress-fill");
  const timeDisplay = document.getElementById("time-display");
  const gatedCount = document.getElementById("gated-count");

  let tokens = [];
  let pos = 0;
  let timer = null;

  function render() {
    const shown = tokens.slice(0, pos);
    stream.innerHTML =
      shown
        .map((t) => {
          const txt = (t.token || "").replace(/</g, "&lt;").replace(/>/g, "&gt;");
          return t.gated
            ? `<span style="background: rgba(240,162,75,0.35); border-radius: 3px; padding: 0 2px;" title="gated write">${txt}</span>`
            : `<span>${txt}</span>`;
        })
        .join("") || '<span style="color: var(--ink-mute);">Press play to stream the trace…</span>';
    const cur = tokens[pos - 1];
    entropyReadout.textContent = cur ? Number(cur.entropy).toFixed(2) : "—";
    tokenIdx.textContent = String(pos);
    const pct = tokens.length ? Math.round((pos / tokens.length) * 100) : 0;
    progressFill.style.width = pct + "%";
    timeDisplay.textContent = `${pos}/${tokens.length}`;
    if (cur && cur.gated) {
      gateIndicator.textContent = "⚡ gated write";
      gateIndicator.style.color = "var(--amber)";
      gateIndicator.style.borderColor = "var(--amber-soft)";
    } else {
      gateIndicator.textContent = "gate idle";
      gateIndicator.style.color = "var(--ink-mute)";
      gateIndicator.style.borderColor = "var(--hairline)";
    }
    stream.scrollTop = stream.scrollHeight;
  }

  function stop() {
    if (timer) { clearInterval(timer); timer = null; }
    playButton.textContent = "▶ Play";
  }

  function play() {
    if (!tokens.length) return;
    if (pos >= tokens.length) pos = 0;
    playButton.textContent = "⏸ Pause";
    timer = setInterval(() => {
      pos++;
      render();
      if (pos >= tokens.length) stop();
    }, 140);
  }

  playButton?.addEventListener("click", () => (timer ? stop() : play()));
  resetButton?.addEventListener("click", () => { stop(); pos = 0; render(); });

  fetch(url)
    .then((r) => (r.ok ? r.json() : null))
    .then((d) => {
      if (!d || !Array.isArray(d.tokens)) {
        stream.innerHTML = '<span style="color: var(--ink-mute);">Trace data unavailable.</span>';
        return;
      }
      tokens = d.tokens;
      tokenTotal.textContent = String(tokens.length);
      gatedCount.textContent = String(tokens.filter((t) => t.gated).length);
      render();
    })
    .catch(() => {
      stream.innerHTML = '<span style="color: var(--ink-mute);">Trace data unavailable.</span>';
    });
</script>
