---
// Depth Toggle — Explorer vs Researcher mode
// Persisted in localStorage
// Accessible toggle with aria-pressed for screen readers
---

<div class="depth-toggle" role="group" aria-label="Depth mode selector">
  <button
    class="depth-button active"
    id="depth-explorer"
    data-depth="explorer"
    aria-pressed="true"
    aria-label="Explorer mode - simplified explanations"
  >
    ◯ Explorer
  </button>
  <button
    class="depth-button inactive"
    id="depth-researcher"
    data-depth="researcher"
    aria-pressed="false"
    aria-label="Researcher mode - technical details"
  >
    ◉ Researcher
  </button>
</div>

<script define:vars={{ depth: 'explorer' }}>
  const DEPTH_KEY = 'prabodha-depth';

  function setDepth(newDepth) {
    document.documentElement.classList.remove('depth-explorer', 'depth-researcher');
    document.documentElement.classList.add(`depth-${newDepth}`);
    localStorage.setItem(DEPTH_KEY, newDepth);

    // Update button states and aria-pressed
    const explorerBtn = document.getElementById('depth-explorer');
    const researcherBtn = document.getElementById('depth-researcher');

    explorerBtn.classList.toggle('active', newDepth === 'explorer');
    explorerBtn.classList.toggle('inactive', newDepth === 'researcher');
    explorerBtn.setAttribute('aria-pressed', newDepth === 'explorer');

    researcherBtn.classList.toggle('active', newDepth === 'researcher');
    researcherBtn.classList.toggle('inactive', newDepth === 'explorer');
    researcherBtn.setAttribute('aria-pressed', newDepth === 'researcher');
  }

  // Load saved depth or default to explorer
  const saved = localStorage.getItem(DEPTH_KEY) || 'explorer';
  setDepth(saved);

  // Wire up buttons
  document.getElementById('depth-explorer')?.addEventListener('click', () => setDepth('explorer'));
  document.getElementById('depth-researcher')?.addEventListener('click', () => setDepth('researcher'));
</script>
