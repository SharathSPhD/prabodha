---
// Depth Toggle — Curious vs Researcher mode, persisted in localStorage.
// Plain inline script (not hoisted/bundled) so it always runs after the DOM exists.
---

<div class="depth-toggle" role="group" aria-label="Reading depth">
  <button
    type="button"
    class="depth-button active"
    id="depth-explorer"
    aria-pressed="true"
    aria-label="Curious mode — plain-language explanations"
  >For the curious</button>
  <button
    type="button"
    class="depth-button inactive"
    id="depth-researcher"
    aria-pressed="false"
    aria-label="Researcher mode — full technical detail"
  >For researchers</button>
</div>

<script is:inline>
  (function () {
    var KEY = 'prabodha-depth';

    function setDepth(mode) {
      var root = document.documentElement;
      root.classList.remove('depth-explorer', 'depth-researcher');
      root.classList.add('depth-' + mode);
      try { localStorage.setItem(KEY, mode); } catch (e) {}

      var ex = document.getElementById('depth-explorer');
      var re = document.getElementById('depth-researcher');
      if (!ex || !re) return;
      var exActive = mode === 'explorer';
      ex.classList.toggle('active', exActive);
      ex.classList.toggle('inactive', !exActive);
      ex.setAttribute('aria-pressed', String(exActive));
      re.classList.toggle('active', !exActive);
      re.classList.toggle('inactive', exActive);
      re.setAttribute('aria-pressed', String(!exActive));
    }

    function init() {
      var saved = 'explorer';
      try { saved = localStorage.getItem(KEY) || 'explorer'; } catch (e) {}
      setDepth(saved);
      var ex = document.getElementById('depth-explorer');
      var re = document.getElementById('depth-researcher');
      if (ex) ex.addEventListener('click', function () { setDepth('explorer'); });
      if (re) re.addEventListener('click', function () { setDepth('researcher'); });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
