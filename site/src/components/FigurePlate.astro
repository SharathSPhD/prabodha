---
// A paper figure, typeset on a light "plate" — SVGs compiled 1:1 from the
// ICML paper's pgfplots sources (site/scripts/build-figures.sh). Every
// coordinate in these figures was generated from committed gate JSONs.
interface Props {
  name: string;        // e.g. "fig_core" → /figures/fig_core.svg
  figNo: string;       // e.g. "Paper Fig. 4"
  caption: string;
  gates?: string[];    // gate file chips
  alt: string;
  maxWidth?: string;   // optional cap, e.g. "560px"
}
const { name, figNo, caption, gates = [], alt, maxWidth } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<figure class="my-8">
  <div class="figure-plate">
    <img
      src={`${base}/figures/${name}.svg`}
      alt={alt}
      loading="lazy"
      style={maxWidth ? `max-width:${maxWidth}; margin:0 auto;` : undefined}
    />
  </div>
  <figcaption class="fig-caption">
    <span class="fig-no">{figNo}</span>{caption}
    {gates.length > 0 && (
      <span class="block mt-2">
        {gates.map((g) => <span class="gate-chip">{g}</span>)}
      </span>
    )}
  </figcaption>
</figure>
