# Gateway authentication (REQUIRED)
STEER_GATEWAY_SECRET=your-secret-key-here

# Model and lens configuration (optional, with defaults)
PRABODHA_MODEL_CONFIG=configs/models/qwen3.yaml
PRABODHA_LENS_FILE=outputs/l10/lens_qwen3_mid30.pt
PRABODHA_SITE=24
PRABODHA_MAX_NEW_TOKENS=100
PRABODHA_MIN_GAP=2
PRABODHA_TAU_PERCENTILE=60

# Logging
LOG_LEVEL=info
