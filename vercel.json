{
  "projectSettings": {
    "name": "prabodha-web",
    "framework": "nextjs",
    "buildCommand": "npm run build",
    "outputDirectory": ".next",
    "installCommand": "npm ci"
  },
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": {
      "description": "Supabase project URL"
    },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": {
      "description": "Supabase anonymous API key"
    },
    "STEER_GATEWAY_SECRET": {
      "description": "Bearer token for gateway auth (server-side only)"
    },
    "NEXT_PUBLIC_STEER_GATEWAY_URL": {
      "description": "Gateway endpoint URL (e.g., https://spark.tailnet.ts.net:8443)"
    }
  },
  "buildIgnore": "git diff --quiet HEAD~1 -- apps/web && echo 1 || echo 0",
  "regions": ["sfo1"],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/",
      "permanent": false
    }
  ]
}
