# Supabase (public; the anon key is safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gateway secret (server-side only; never sent to browser)
STEER_GATEWAY_SECRET=dev-secret-key

# Local development mode (skips Supabase entirely)
# NEXT_PUBLIC_FORCE_LOCAL_MODE=true
